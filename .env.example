# JWT
# REQUIRED: replace with a real 32+ byte secret. Services refuse to start if
# Jwt:Secret is empty, shorter than 32 bytes, or contains 'change-in-production'.
# Generate one with: openssl rand -base64 48
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ISSUER=prm-dashboard
JWT_AUDIENCE=prm-dashboard-client
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# Data path
# Runtime services read per-tenant Parquet files from ./data on the host.
# docker-compose.yml mounts ./data into each container at /app/data and sets
# PRM_DATA_PATH=/app/data. CSVs + Parquet files are committed under data/;
# use tools/PrmDashboard.ParquetBuilder to regenerate Parquet from the CSVs.

# Service Ports
# Only the gateway is exposed to the host; auth/tenant/prm are reachable
# only via the internal Docker network on container port 8080.
GATEWAY_PORT=5000
