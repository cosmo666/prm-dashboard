# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_MASTER_DB=prm_master

# JWT
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ISSUER=prm-dashboard
JWT_AUDIENCE=prm-dashboard-client
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# Tenant DBs
# Database names are currently hardcoded in database/init/02-tenant-schema.sql
# as aeroground_db, skyserve_db, globalprm_db. If you add a new tenant, update
# both the SQL init script and the 03-seed-tenants.sql seeds (Task 10).

# Service Ports
GATEWAY_PORT=5000
AUTH_PORT=5001
TENANT_PORT=5002
PRM_PORT=5003
