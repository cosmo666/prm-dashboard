# MySQL (LEGACY — only used by the data-export pipeline; gated behind the
# `data-pipeline` profile, won't start on default `docker compose up`)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_MASTER_DB=prm_master

# JWT
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ISSUER=prm-dashboard
JWT_AUDIENCE=prm-dashboard-client
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# Data path
# Runtime services read per-tenant Parquet files from ./data on the host.
# docker-compose.yml mounts ./data into each container at /app/data and sets
# PRM_DATA_PATH=/app/data. To regenerate parquet files from the legacy MySQL
# source, run the one-shot pipeline:
#   docker compose --profile data-pipeline up mysql -d
#   dotnet run --project backend/tools/PrmDashboard.CsvExporter
#   dotnet run --project backend/tools/PrmDashboard.ParquetBuilder

# Service Ports
# Only the gateway is exposed to the host; auth/tenant/prm are reachable
# only via the internal Docker network on container port 8080.
GATEWAY_PORT=5000
